# Required in production. Development uses admin@local.dev / admin123 when omitted.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-password
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret

# Contact form delivery through Resend.
RESEND_API_KEY=re_replace-with-your-api-key
CONTACT_FROM_EMAIL=Portfolio <contact@your-verified-domain.com>
CONTACT_TO_EMAIL=you@example.com
